{
  "expo": {
    "name": "Presenca",
    "slug": "presenca-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.presenca.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localizacao para registrar sua presenca.",
        "NSLocationAlwaysUsageDescription": "Precisamos da sua localizacao para registrar sua presenca."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.presenca.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "publicPath": "/mobile/",
      "pwa": {
        "short_name": "Presenca",
        "name": "Presenca - Controle de Ponto",
        "theme_color": "#2563EB",
        "background_color": "#F3F4F6",
        "display": "standalone",
        "start_url": "/mobile/",
        "orientation": "portrait",
        "icons": [
          {
            "src": "/mobile/icons/icon-192.png",
            "sizes": "192x192",
            "type": "image/png"
          },
          {
            "src": "/mobile/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png"
          }
        ]
      }
    },
    "plugins": ["expo-location"]
  }
}
