{
  "buildCommand": "expo export --platform web",
  "outputDirectory": "dist",
  "devCommand": "expo",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/mobile/:path*",
      "destination": "/mobile/:path*"
    },
    {
      "source": "/mobile",
      "destination": "/mobile/index.html"
    }
  ]
}
